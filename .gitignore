# Ignore everything in target/ but allow specific tracked subdirectories/files.
# Must use tr4w/target/* (not tr4w/target/) so git descends into the directory
# and honours the negation rules below. A trailing-slash ignore pattern causes
# git to skip the directory entirely, making negations inside it ineffective.
#
# cty.dat note: the file IS tracked in master (so fresh clones get a working
# copy), but it is intentionally NOT re-included via negation here.  TR4W
# rewrites cty.dat at runtime; we no longer want those local edits to surface
# in `git status` or be accidentally committed.  Each developer should also
# run `git update-index --skip-worktree tr4w/target/cty.dat` once locally to
# fully silence cty.dat from status.  If the master copy ever genuinely needs
# updating, `git add -f tr4w/target/cty.dat` bypasses this ignore.
tr4w/target/*
!tr4w/target/dom
!tr4w/target/trcluster.dat
!tr4w/target/commands*.ini
tr4w/tr4w.cfg
tr4w/tr4w.dof
# Generated each build by FullBuild.ps1 Write-VersionInfoResource: a
# language- and version-specific VERSIONINFO PE resource picked up by
# tr4w.dpr via {$IFDEF VERSIONINFO_RES}{$R tr4w_versioninfo.res}{$ENDIF}.
# Files never need to be tracked -- always regenerated.
tr4w/tr4w_versioninfo.rc
tr4w/tr4w_versioninfo.res
tr4w/COMPILER.LOG
tr4w/tr4w.log
*.RST
*.TRW
*.LOG

# Build output text files
tr4w/build_*.txt
tr4w/COMPILATION_RESULTS.txt
tr4w/compile_*.txt
tr4w/tr4w.log.*
tr4w/build_*.log

# Claude Code local config and memory
.claude/
tr4w/.claude/

# Network capture files (local debugging only)
*.pcap
*.pcapng

# GitHub Wiki — separate repo at n4af/TR4W.wiki.git, cloned locally for editing
wiki/
